# Copia este archivo a `.env` (no lo subas al repositorio).
#
# Datos CNE (elige UNA opción):
# - Producción recomendada: URL de un proxy tuyo (Cloudflare Worker, Vercel, etc.) que llame a
#   https://api.cne.cl/api/v4/estaciones con Authorization: Bearer <token> solo en el servidor.
#   Así el token no va en el APK y lo renuevas sin republicar la app.
# CNE_STATIONS_URL=https://tu-dominio.example/cne/estaciones
#
# - Desarrollo / MVP: token directo (caduca; queda expuesto si alguien extrae el binario).
# CNE_API_TOKEN=
CNE_STATIONS_URL=
CNE_API_TOKEN=

# Opcional: IDs de aplicación AdMob (producción). Si omites, se usan IDs de prueba de Google.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# Opcional: unidades de banner (producción). En desarrollo se usan TestIds del SDK.
ADMOB_BANNER_ANDROID_ID=
ADMOB_BANNER_IOS_ID=

# Opcional: EAS project id (solo si cambias de proyecto). Si lo dejas vacío, app.config.js usa el id por defecto.
# EAS_PROJECT_ID=
